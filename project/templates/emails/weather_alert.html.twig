<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Weather Alert</title>
</head>
<body>
<h1>Weather Alert for {{ city }}</h1>
<p>Hello!</p>
<p>This is an automated notification from <strong>symfonyweatherreminder.mooo.com</strong>.</p>
<div style="padding: 20px; background-color: #f8d7da; border: 1px solid #f5c6cb; border-radius: 5px;">
    <p>{{ alert_message }}</p>
    <p>Current temperature: <strong>{{ current_temp }}°C</strong></p>
</div>
<p>Stay safe!</p>
</body>
</html>
